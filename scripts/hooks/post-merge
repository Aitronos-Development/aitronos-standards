#!/usr/bin/env bash
# Aitronos Standards — Post-merge hook
# Auto-syncs shared standards after git pull / git merge.
# Installed by .standards/scripts/setup.sh

# Only run if .standards submodule changed in this merge
if git diff-tree -r --name-only ORIG_HEAD HEAD 2>/dev/null | grep -q "^\.standards"; then
  echo ""
  echo "📦 Standards submodule changed — syncing new rules/skills/agents..."
  echo ""

  # Initialize and update the submodule first
  git submodule update --init .standards 2>/dev/null

  # Run the update script (skips pull since submodule is already at the right commit)
  if [ -x ".standards/scripts/update.sh" ]; then
    .standards/scripts/update.sh --no-pull
  fi
fi
