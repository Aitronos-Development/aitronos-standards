#!/usr/bin/env bash
# flowplate-branch-protection-v1
# Aitronos Standards — Pre-push hook
#
# 1. Blocks direct pushes to protected branches (develop, main, etc.)
# 2. Blocks pushes that delete more than 30% of tracked files
#
# The branch protection is also enforced server-side (GitHub ruleset),
# but this gives fast, friendly errors before the round-trip.
#
# Installed automatically by .standards/scripts/setup.sh

set -euo pipefail

PROTECTED_BRANCHES="develop main master production"
DELETION_THRESHOLD=30  # percent

remote="$1"

while read -r local_ref local_oid remote_ref remote_oid; do
	branch_name="${remote_ref#refs/heads/}"

	# ── Check 1: Block pushes to protected branches ────────────────────
	for protected in $PROTECTED_BRANCHES; do
		if [ "$branch_name" = "$protected" ]; then
			echo ""
			echo "╔══════════════════════════════════════════════════════════╗"
			echo "║  BLOCKED: Direct push to '$protected' is not allowed.   ║"
			echo "╠══════════════════════════════════════════════════════════╣"
			echo "║  Create a feature branch and open a PR instead:         ║"
			echo "║                                                         ║"
			echo "║    scripts/git/new-branch.sh feat my-feature            ║"
			echo "║    # ... make changes ...                               ║"
			echo "║    scripts/git/submit.sh                                ║"
			echo "║                                                         ║"
			echo "║  This rule is also enforced server-side by GitHub.      ║"
			echo "║  Even --no-verify won't help — GitHub will reject it.   ║"
			echo "╚══════════════════════════════════════════════════════════╝"
			echo ""
			exit 1
		fi
	done

	# ── Check 2: Block mass deletions ──────────────────────────────────
	# Skip branch deletes (all zeros)
	if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
		continue
	fi
	# Skip new branches (no remote_oid to compare against)
	if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
		continue
	fi

	total=$(git ls-tree -r --name-only "$remote_oid" 2>/dev/null | wc -l | tr -d ' ')
	deleted=$(git diff --diff-filter=D --name-only "$remote_oid" "$local_oid" 2>/dev/null | wc -l | tr -d ' ')

	if [ "$total" -gt 0 ]; then
		percent=$((deleted * 100 / total))
		if [ "$percent" -gt "$DELETION_THRESHOLD" ]; then
			echo ""
			echo "PUSH BLOCKED — mass deletion detected"
			echo ""
			echo "   This push deletes $deleted of $total files (${percent}%)."
			echo "   Threshold: ${DELETION_THRESHOLD}%"
			echo ""
			echo "   If this is intentional, bypass with:  git push --no-verify"
			echo ""
			exit 1
		fi
	fi
done

exit 0
