#!/usr/bin/env bash
# aitronos-safe-push-v1
# Aitronos Standards — Pre-push safety hook
#
# Prevents accidental code loss when multiple people push to the same branch.
# Three checks:
#   1. Auto-fetch remote and REFUSE if local is behind (must pull first)
#   2. Create a backup tag before every push (so nothing is ever truly lost)
#   3. Block pushes that mass-delete files (>30% of tracked files)

set -euo pipefail

DELETION_THRESHOLD=30  # percent

remote="$1"

while read -r local_ref local_oid remote_ref remote_oid; do
	branch_name="${remote_ref#refs/heads/}"

	# Skip branch deletes
	if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
		continue
	fi

	# ── Check 1: Refuse push if behind remote ─────────────────────────
	# Fetch the latest state of this branch from the remote
	git fetch "$remote" "$branch_name" --quiet 2>/dev/null || true

	REMOTE_HEAD="$(git rev-parse "refs/remotes/$remote/$branch_name" 2>/dev/null || true)"

	if [ -n "$REMOTE_HEAD" ] && [ "$REMOTE_HEAD" != "$local_oid" ]; then
		# Check if remote head is an ancestor of local (we're ahead = safe)
		if ! git merge-base --is-ancestor "$REMOTE_HEAD" "$local_oid" 2>/dev/null; then
			echo ""
			echo "╔══════════════════════════════════════════════════════════╗"
			echo "║  BLOCKED: Remote '$branch_name' has commits you don't   ║"
			echo "║  have locally. Pull first to avoid overwriting work.    ║"
			echo "╠══════════════════════════════════════════════════════════╣"
			echo "║                                                         ║"
			echo "║    git pull --rebase origin $branch_name"
			echo "║                                                         ║"
			echo "║  This ensures your teammates' changes are preserved.    ║"
			echo "╚══════════════════════════════════════════════════════════╝"
			echo ""
			exit 1
		fi
	fi

	# ── Check 2: Auto-backup before push ──────────────────────────────
	# Create a timestamped backup tag so the pre-push state can always
	# be recovered, even if the push introduces a bad merge.
	BACKUP_TAG="backup/${branch_name}/$(date -u +%Y%m%d-%H%M%S)"
	git tag "$BACKUP_TAG" "$local_oid" 2>/dev/null || true

	# Keep only the last 20 backup tags for this branch (prune old ones)
	git tag -l "backup/${branch_name}/*" | sort | head -n -20 | while read -r old_tag; do
		git tag -d "$old_tag" 2>/dev/null || true
	done

	# ── Check 3: Block mass deletions ─────────────────────────────────
	# Skip if remote is a new branch (no remote_oid to compare against)
	if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
		continue
	fi

	total=$(git ls-tree -r --name-only "$remote_oid" 2>/dev/null | wc -l | tr -d ' ')
	deleted=$(git diff --diff-filter=D --name-only "$remote_oid" "$local_oid" 2>/dev/null | wc -l | tr -d ' ')

	if [ "$total" -gt 0 ]; then
		percent=$((deleted * 100 / total))
		if [ "$percent" -gt "$DELETION_THRESHOLD" ]; then
			echo ""
			echo "╔══════════════════════════════════════════════════════════╗"
			echo "║  BLOCKED: Mass deletion detected.                       ║"
			echo "║  This push deletes $deleted of $total files (${percent}%).          ║"
			echo "║  Threshold: ${DELETION_THRESHOLD}%                                      ║"
			echo "╠══════════════════════════════════════════════════════════╣"
			echo "║  If intentional: git push --no-verify                   ║"
			echo "╚══════════════════════════════════════════════════════════╝"
			echo ""
			exit 1
		fi
	fi
done

exit 0
