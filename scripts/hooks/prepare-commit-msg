#!/usr/bin/env bash
# ============================================================================
# Aitronos Standards — prepare-commit-msg hook
#
# Strips AI attribution (Co-Authored-By, Signed-off-by) from commit messages.
# Commits must use the developer's git identity only — no AI footprint.
# ============================================================================

COMMIT_MSG_FILE="$1"

if [ ! -f "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

# Remove any line containing AI co-author or sign-off patterns (case-insensitive)
# Covers: Claude, Anthropic, Cursor, GitHub Copilot, OpenAI, GPT, Gemini, AI assistants
sed -i.bak -E \
  -e '/^[[:space:]]*(Co-Authored-By|Co-authored-by|Signed-off-by)[[:space:]]*:.*([Cc]laude|[Aa]nthrop|[Cc]ursor|[Cc]opilot|[Oo]pen[Aa][Ii]|[Gg][Pp][Tt]|[Gg]emini|[Aa][Ii][ _-]?[Aa]ssistant|noreply@anthropic|github-actions\[bot\])/d' \
  "$COMMIT_MSG_FILE"

# Clean up trailing blank lines left after removal
sed -i.bak -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$COMMIT_MSG_FILE"

# Remove backup file created by sed -i on macOS
rm -f "${COMMIT_MSG_FILE}.bak"

exit 0
